## Sub-Components (When Needed)

```typescript
// icon-wrapper.tsx
import { View } from '../view'; // ← Use atom, not primitive!
import { styles } from './styles';

export function IconWrapper({ children, position, size }) {
  if (!children) return null;
  return (
    <View style={[
      styles.iconWrapper,
      { width: size, height: size },
      position === 'left' && styles.iconLeft,
      position === 'right' && styles.iconRight,
    ]}>
      {children}
    </View>
  );
}
```

