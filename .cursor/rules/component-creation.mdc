## 4. index.tsx - Composition Only

```typescript
import type { View } from 'react-native';
import type { ComponentProps } from './types';

import * as React from 'react';
import { ActivityIndicator, Pressable, Text } from '@/components'; // ← Use atoms!
import { DISABLED_CONFIG, SIZE_CONFIG, VARIANT_CONFIG } from './constants';
import { styles } from './styles';

export type { ComponentProps, ComponentSize, ComponentVariant } from './types';

export function Component({
  ref,
  label,
  loading = false,
  variant = 'default',
  disabled = false,
  size = 'default',
  leftIcon,
  rightIcon,
  style,
  textStyle,
  testID,
  accessibilityLabel,
  accessibilityHint,
  children,
  android_ripple,
  ...props
}: ComponentProps & { ref?: React.Ref<View | null> }) {
  // Resolve config
  const variantConfig = disabled ? DISABLED_CONFIG : VARIANT_CONFIG[variant];
  const sizeConfig = SIZE_CONFIG[size];

  // Compose styles
  const containerStyle = [
    styles.base,
    variantConfig.containerStyle,
    sizeConfig.containerStyle,
    style,
  ];

  const labelStyle = [
    styles.label,
    variantConfig.labelStyle,
    sizeConfig.labelStyle,
    textStyle,
  ];

  return (
    <Pressable
      ref={ref}
      disabled={disabled || loading}
      style={containerStyle}
      testID={testID}
      accessibilityRole="button"
      accessibilityLabel={accessibilityLabel || label}
      accessibilityHint={accessibilityHint}
      accessibilityState={{
        disabled: disabled || loading,
        busy: loading,
      }}
      android_ripple={android_ripple || { color: variantConfig.rippleColor }}
      {...props}
    >
      {loading && (
        <ActivityIndicator
          size="small"
          color={variantConfig.indicatorColor}
          style={styles.loadingSpinner}
        />
      )}
      {children || (
        <>
          {leftIcon}
          {label && <Text style={labelStyle}>{label}</Text>}
          {rightIcon}
        </>
      )}
    </Pressable>
  );
}

Component.displayName = 'Component';
```

