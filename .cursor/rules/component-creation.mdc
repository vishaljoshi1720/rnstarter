## Testing Template

```typescript
describe('Component', () => {
  it('renders correctly', () => {
    render(<Component testID="test" />);
    expect(screen.getByTestId('test')).toBeOnTheScreen();
  });

  it('handles interaction', async () => {
    const handler = jest.fn();
    const { user } = setup(<Component onPress={handler} testID="test" />);
    await user.press(screen.getByTestId('test'));
    expect(handler).toHaveBeenCalled();
  });

  it('respects disabled state', () => {
    render(<Component disabled testID="test" />);
    expect(screen.getByTestId('test')).toBeDisabled();
  });

  it('shows loading indicator', () => {
    render(<Component loading testID="test" />);
    expect(screen.getByTestId('test-activity-indicator')).toBeOnTheScreen();
  });
});
```

