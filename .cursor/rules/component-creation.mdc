## 2. types.ts - Union Types, Not Enums

```typescript
import type { PressableProps, StyleProp, ViewStyle, TextStyle } from 'react-native';

// ✅ Union types (NOT enums)
export type ComponentVariant = 'default' | 'primary' | 'secondary';
export type ComponentSize = 'sm' | 'default' | 'lg';

export type ComponentProps = {
  // Core
  label?: string;
  value?: boolean;
  onValueChange?: (value: boolean) => void;
  
  // State
  loading?: boolean;
  variant?: ComponentVariant;
  size?: ComponentSize;
  disabled?: boolean;
  
  // Icons
  leftIcon?: React.ReactNode;
  rightIcon?: React.ReactNode;
  children?: React.ReactNode;
  
  // Style
  style?: StyleProp<ViewStyle>;
  textStyle?: StyleProp<TextStyle>;
  
  // Accessibility
  testID?: string;
  accessibilityLabel?: string;
  accessibilityHint?: string;
  
  // Platform
  android_ripple?: PressableProps['android_ripple'];
} & Omit<PressableProps, 'disabled'>;
```

