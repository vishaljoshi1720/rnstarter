# Environment variables (committed — safe defaults / placeholders only)
#
# Setup:
#   cp .env.example .env.local
#   # edit .env.local — never commit it
#
# Rules:
#   • EXPO_PUBLIC_* is inlined into the JS bundle → PUBLIC. No secrets.
#   • Private keys / tokens → your backend, or EAS "secret" for build tooling only.
#   • Cloud builds: set the same keys in EAS (development / preview / production).
#   • Prefer `eas env:pull --environment preview` over juggling NODE_ENV files.
#
# Docs: docs/environment.md

# development | preview | production
EXPO_PUBLIC_APP_ENV=development

# Backend API base URL (required for preview + production builds)
EXPO_PUBLIC_API_URL=http://127.0.0.1:3000

# Optional: https origin for iOS Universal Links + Android App Links.
# Only uncomment after you host apple-app-site-association + assetlinks.json
# (autoVerify is enabled when this is set).
# EXPO_PUBLIC_ASSOCIATED_DOMAIN=https://app.example.com
